{
  "name": "websitepls",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "trap 'kill 0' EXIT; NODE_OPTIONS='--dns-result-order=ipv4first' tsx src/workers/generation-worker.ts & NODE_OPTIONS='--dns-result-order=ipv4first' next dev --turbopack",
    "build": "next build",
    "start": "NODE_OPTIONS='--dns-result-order=ipv4first' next start",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "frontend": "next dev --turbopack",
    "worker:generate": "tsx src/workers/generation-worker.ts",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.52",
    "@ai-sdk/provider": "^3.0.8",
    "@anthropic-ai/sdk": "^0.109.1",
    "@ariakit/react": "^0.4.31",
    "@auth/prisma-adapter": "^2.11.2",
    "@aws-sdk/client-s3": "^3.1078.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "ai": "^6.0.158",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.79.2",
    "dotenv": "^17.4.2",
    "ioredis": "^5.11.1",
    "js-tiktoken": "^1.0.21",
    "linkedom": "^0.18.12",
    "lucide-react": "^0.563.0",
    "next": "16.2.10",
    "next-auth": "5.0.0-beta.30",
    "next-intl": "^4.13.1",
    "openai": "^6.45.0",
    "pg": "^8.22.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "resend": "^6.16.0",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "unpdf": "1.6.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "prisma": "^7.5.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "packageManager": "pnpm@10.15.1+sha512.34e538c329b5553014ca8e8f4535997f96180a1d0f614339357449935350d924e22f8614682191264ec33d1462ac21561aff97f6bb18065351c162c7e8f6de67",
  "pnpm": {
    "overrides": {
      "fast-xml-parser": ">=5.7.0"
    }
  }
}
