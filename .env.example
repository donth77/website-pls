# PostgreSQL
#
# Supabase: many home / VPN networks cannot reach the DIRECT host (db.<ref>.supabase.co) —
# it is IPv6-first; use IPv4-friendly Session pooler instead.
#
# Dashboard → Connect → Connection string → Session pooler (port 5432), e.g.:
#   postgresql://postgres.<project-ref>:PASSWORD@aws-0-<REGION>.pooler.supabase.com:5432/postgres?sslmode=require
#
# Local Postgres example:
#   DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/website_generator?schema=public
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require

# Read-only connection for safe ad-hoc queries (Claude Code, debugging, etc.).
# Create a read-only Postgres role in Supabase SQL Editor:
#
#   CREATE ROLE readonly_agent WITH LOGIN PASSWORD 'STRONG_PASSWORD';
#   GRANT CONNECT ON DATABASE postgres TO readonly_agent;
#   GRANT USAGE ON SCHEMA public TO readonly_agent;
#   GRANT SELECT ON ALL TABLES IN SCHEMA public TO readonly_agent;
#   ALTER DEFAULT PRIVILEGES IN SCHEMA public GRANT SELECT ON TABLES TO readonly_agent;
#
# Then build a connection string using that role:
DATABASE_URL_READONLY=

# Supabase (used for persistence + generated assets)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Use a service role key for server-side access (keep private; do not ship to browser).
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
# Bucket where we store generated output (index.html, assets later).
SUPABASE_STORAGE_BUCKET=generated-sites

# Redis (BullMQ queue worker)
#
# Local:
#   REDIS_URL=redis://localhost:6379
#
# Upstash (TLS): in the Upstash console open your database → copy the **Redis** connection string
# from the **Node** / **Redis** tab (starts with rediss://). Do NOT use the REST URL.
#   Example: rediss://default:YOUR_TOKEN@YOUR_ENDPOINT.upstash.io:6379
# The app expands rediss:// into host/port/password + TLS options (matches Upstash’s BullMQ guide).
#
# Note: BullMQ polls Redis; on Upstash pay-as-you-go this can add up — consider a fixed plan for steady queues.
REDIS_URL=redis://localhost:6379

# Optional: force IPv4 if your network breaks IPv6 routes (try "4" if connections reset).
# REDIS_FAMILY=4

# Worker-only: ioredis disconnect timeout (ms). Default 0 helps BullMQ + some managed Redis (e.g. Upstash).
# For local Redis you can set REDIS_WORKER_DISCONNECT_TIMEOUT=2000
# REDIS_WORKER_DISCONNECT_TIMEOUT=0

# AI provider
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY
# Models that support structured outputs (recommended): claude-sonnet-4-5-20250514, claude-haiku-4-5-20250514
# Older models (fallback, no structured output): claude-3-5-sonnet-20241022
ANTHROPIC_MODEL=claude-sonnet-4-5-20250514

# Images — Unsplash (optional but recommended)
#
# Generated sites use real photos from Unsplash, searched by each <img> alt text.
# Without this key, images stay as whatever the model outputs (often broken hotlinks).
#
# Sign up at https://unsplash.com/developers → create an app → copy your Access Key.
# Free tier: 50 requests/hour (demo), 5000/hour after production approval.
UNSPLASH_ACCESS_KEY=YOUR_UNSPLASH_ACCESS_KEY

# Images — Pexels (optional fallback for Unsplash)
#
# If Unsplash returns no results or is down/rate-limited, Pexels is tried next.
# Sign up at https://www.pexels.com/api/ → copy your API key.
# Free tier: 200 requests/hour.
PEXELS_API_KEY=YOUR_PEXELS_API_KEY

# Lakera Guard — optional prompt / abuse screening before generation
# https://platform.lakera.ai — create API key and (recommended) a project + custom policy.
# If unset, screening is skipped (fine for local dev).
# LAKERA_API_KEY=
# LAKERA_PROJECT_ID=   # optional; uses platform default policy if omitted
# LAKERA_API_URL=https://api.lakera.ai   # optional regional host, see Lakera docs

# Auth — secret for HMAC-signing guest session cookies + NextAuth session tokens.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=

# Admin — secret for the cleanup cron endpoint (POST /api/admin/cleanup).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Pass as: Authorization: Bearer $CLEANUP_SECRET
CLEANUP_SECRET=

# OAuth — Google (optional, enables "Sign in with Google")
# https://console.cloud.google.com/apis/credentials → Create OAuth 2.0 Client ID
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# OAuth — GitHub (optional, enables "Sign in with GitHub")
# https://github.com/settings/developers → New OAuth App
# Authorization callback URL: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Email magic link — Resend (optional, enables "Sign in with email")
# https://resend.com → create API key + verify a sending domain
# AUTH_RESEND_KEY is the Resend API key.
# EMAIL_FROM is the "From" address for magic link emails.
AUTH_RESEND_KEY=
EMAIL_FROM=noreply@yourdomain.com

# Cloudflare Turnstile — bot mitigation for the /api/generate endpoint
# https://developers.cloudflare.com/turnstile/get-started/
# Create a widget at https://dash.cloudflare.com → Turnstile, then copy keys.
# If unset, Turnstile verification is skipped (fine for local dev).
# Test keys: site=1x00000000000000000000AA secret=1x0000000000000000000000000000000AA (always pass)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
