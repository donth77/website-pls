// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ProjectStatus {
  DRAFT
  GENERATING
  READY
  ERROR
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  name          String?
  image         String?
  plan          String    @default("free")
  credits       Int       @default(10)
  createdAt     DateTime  @default(now()) @map("created_at")
  projects      Project[]
  accounts      Account[]
  sessions      Session[]

  @@map("users")
}

model Account {
  id                String  @id @default(uuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model GuestSession {
  id              String    @id @default(uuid())
  ipAddress       String    @map("ip_address")
  generationsUsed Int       @default(0) @map("generations_used")
  createdAt       DateTime  @default(now()) @map("created_at")
  expiresAt       DateTime  @map("expires_at")
  projects        Project[]

  @@index([expiresAt])
  @@map("guest_sessions")
}

model Project {
  id             String        @id @default(uuid())
  userId         String?       @map("user_id")
  user           User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  guestSessionId String?       @map("guest_session_id")
  guestSession   GuestSession? @relation(fields: [guestSessionId], references: [id], onDelete: SetNull)
  name           String
  prompt         String?       @db.Text
  siteSpec       Json?         @map("site_spec")
  status         ProjectStatus @default(DRAFT)
  errorMessage   String?       @map("error_message") @db.Text

  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  versions       Version[]
  publishedSites PublishedSite[]

  @@index([userId])
  @@index([guestSessionId])
  @@map("projects")
}

model Version {
  id            String   @id @default(uuid())
  projectId     String   @map("project_id")
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  versionNumber Int      @map("version_number")
  promptDelta   String?  @map("prompt_delta") @db.Text
  blueprint     Json?
  storageKey    String?  @map("storage_key")
  createdAt     DateTime @default(now()) @map("created_at")

  publishedSites PublishedSite[]

  @@unique([projectId, versionNumber])
  @@index([projectId])
  @@map("versions")
}

model PublishedSite {
  id           String    @id @default(uuid())
  projectId    String    @map("project_id")
  project      Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  versionId    String?   @map("version_id")
  version      Version?  @relation(fields: [versionId], references: [id], onDelete: SetNull)
  subdomain    String?   @unique
  customDomain String?   @map("custom_domain")
  storageKey   String    @map("storage_key")
  isActive     Boolean   @default(true) @map("is_active")
  publishedAt  DateTime  @default(now()) @map("published_at")

  @@index([projectId])
  @@map("published_sites")
}
